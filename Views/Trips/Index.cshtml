@model IEnumerable<MyTripLog.Models.Trip>

@{
    ViewData["Title"] = "My Trip Log";
}

<div class="container mt-4">

    <div class="bg-secondary text-white text-center p-3 mb-4">
        <h2 class="mb-0">My Trip Log</h2>
    </div>

    <a asp-action="Add" class="btn btn-dark mb-3">Add Trip</a>

    <table class="table table-bordered table-striped">
        <thead class="table-light">
            <tr>
                <th>Destination</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Accommodation</th>
                <th>Things To Do</th>
                <th style="width:120px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var trip in Model)
            {
                <tr>
                    <td>@trip.Destination.Name</td>
                    <td>@trip.StartDate.ToShortDateString()</td>
                    <td>@trip.EndDate.ToShortDateString()</td>
                    <td>
                        @trip.Accommodation.Name <br />
                        @if (!string.IsNullOrEmpty(trip.Accommodation.Phone))
                        {
                            <div>Phone: @trip.Accommodation.Phone</div>
                        }
                        @if (!string.IsNullOrEmpty(trip.Accommodation.Email))
                        {
                            <div>Email: @trip.Accommodation.Email</div>
                        }
                    </td>
                    <td>
                        @foreach (var ta in trip.TripActivities)
                        {
                            <div>@ta.Activity.Name</div>
                        }
                    </td>
                    <td>
                        <form asp-action="Delete" method="post">
                            <input type="hidden" name="id" value="@trip.TripId" />
                            <button type="submit" class="btn btn-primary">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>