<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TripLog</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TripLog.styles.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Trips" asp-action="Index">View Trips</a>

            <div class="navbar-nav">
                <a class="nav-link" asp-controller="Destinations" asp-action="Index">Manage Destinations</a>
                <a class="nav-link" asp-controller="Accommodations" asp-action="Index">Manage Accommodations</a>
                <a class="nav-link" asp-controller="Activities" asp-action="Index">Manage Activities</a>
            </div>
        </div>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>
