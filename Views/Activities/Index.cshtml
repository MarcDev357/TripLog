@model IEnumerable<MyTripLog.Models.Activity>

@{
    ViewData["Title"] = "Manage Activities";
}

<h2>Manage Activities</h2>

<form asp-action="Add" method="post" class="mb-3">
    <div class="input-group">
        <input type="text" name="name" class="form-control" placeholder="New Activity" required />
        <button class="btn btn-dark" type="submit">Add</button>
    </div>
</form>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th style="width:120px;"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var activity in Model)
        {
            <tr>
                <td>@activity.Name</td>
                <td>
                    <form asp-action="Delete" method="post">
                        <input type="hidden" name="id" value="@activity.ActivityId" />
                        <button class="btn btn-primary">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>